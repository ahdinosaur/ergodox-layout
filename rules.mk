# Build features used by this keymap.
# https://docs.qmk.fm/squeezing_avr

MOUSEKEY_ENABLE   = yes  # KC_MS_*, KC_BTN1/2 on the MDIA layer
EXTRAKEY_ENABLE   = yes  # KC_VOL*, KC_MUTE, KC_MPLY, KC_WBAK on the MDIA layer

COMMAND_ENABLE    = no
CONSOLE_ENABLE    = no
TAP_DANCE_ENABLE  = no
RGBLIGHT_ENABLE   = no
UNICODE_ENABLE    = no
NKRO_ENABLE       = no
